{
  "name": "jcode-mimir",
  "version": "0.4.0",
  "private": true,
  "description": "Monorepo for the Mimir open-source local RAG packages.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm --filter @jcode.labs/mimir-tts build && pnpm --filter @jcode.labs/mimir build",
    "check": "pnpm --filter @jcode.labs/mimir-tts check && pnpm --filter @jcode.labs/mimir check",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "format": "biome format --write .",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "package:check": "pnpm --filter @jcode.labs/mimir-tts package:check && pnpm --filter @jcode.labs/mimir package:check",
    "release:artifacts": "node scripts/release-artifacts.mjs",
    "smoke": "node scripts/smoke.mjs && pnpm --filter @jcode.labs/mimir-tts smoke",
    "test": "pnpm --filter @jcode.labs/mimir-tts test && pnpm --filter @jcode.labs/mimir test",
    "validate": "pnpm lint && pnpm check && pnpm test && pnpm build && pnpm smoke && pnpm package:check && pnpm release:artifacts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "yaml": "^2.8.1"
  }
}
