{
  "name": "@jcode.labs/ragmir-ui",
  "version": "0.4.10",
  "private": true,
  "description": "Shared Ragmir React UI primitives and Tailwind theme.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "imports": {
    "#components": "./src/components",
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#lib/utils": "./src/lib/utils.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./globals.css": "./src/styles/globals.css",
    "./utils": {
      "types": "./src/lib/utils.ts",
      "import": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "import": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "^5.9.3"
  }
}
