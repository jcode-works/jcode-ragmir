{
  "name": "@jcode.labs/ragmir",
  "version": "0.4.12",
  "description": "Confidential local RAG for coding agents, with offline cited retrieval through CLI, MCP, and TypeScript.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Jean-Baptiste Thery",
    "url": "https://github.com/jb-thery"
  },
  "keywords": [
    "jcode",
    "ragmir",
    "open-source",
    "rag",
    "confidential-rag",
    "ai-agents",
    "coding-agents",
    "knowledge-base",
    "confidential-data",
    "offline-first",
    "cited-retrieval",
    "local-first",
    "mcp",
    "mcp-server",
    "nodejs",
    "typescript",
    "transformers",
    "semantic-search",
    "lancedb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcode-works/jcode-ragmir.git",
    "directory": "packages/ragmir-core"
  },
  "homepage": "https://github.com/jcode-works/jcode-ragmir#readme",
  "bugs": {
    "url": "https://github.com/jcode-works/jcode-ragmir/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ragmir": "dist/cli.js",
    "kb": "dist/cli.js",
    "rgr": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "examples",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bench:compare": "node benchmarks/compare.mjs",
    "bench:concurrency": "pnpm build && node benchmarks/concurrency.mjs",
    "bench:discovery": "pnpm build && node benchmarks/discovery.mjs",
    "bench:ingest-memory": "pnpm build && node benchmarks/ingest-memory.mjs",
    "bench:ingestion-metadata": "pnpm build && node benchmarks/ingestion-metadata.mjs",
    "bench:local-hash-runtime": "pnpm build && node benchmarks/local-hash-runtime.mjs",
    "bench:model-lifecycle": "pnpm build && node benchmarks/model-lifecycle.mjs",
    "bench:ocr": "pnpm build && node benchmarks/ocr-cache.mjs",
    "bench:generations": "pnpm build && node benchmarks/generation-retention.mjs",
    "bench:quality": "pnpm build && node benchmarks/quality.mjs",
    "bench:scale": "pnpm build && node benchmarks/run.mjs --profile scale",
    "bench:smoke": "pnpm build && node benchmarks/verify.mjs && node benchmarks/run.mjs --profile smoke",
    "bench:storage": "pnpm build && node benchmarks/storage-maintenance.mjs",
    "bench:status": "pnpm build && node benchmarks/status.mjs",
    "bench:vector-index": "pnpm build && node benchmarks/vector-index.mjs",
    "build": "tsc -p tsconfig.json",
    "check": "pnpm --filter @jcode.labs/ragmir-tts build && pnpm --filter @jcode.labs/ragmir-chat build && tsc -p tsconfig.json --noEmit",
    "mcp:smoke": "pnpm build && node scripts/mcp-smoke.mjs",
    "package:check": "publint",
    "test": "pnpm --filter @jcode.labs/ragmir-tts build && pnpm --filter @jcode.labs/ragmir-chat build && pnpm build && vitest run",
    "test:coverage": "pnpm --filter @jcode.labs/ragmir-tts build && pnpm --filter @jcode.labs/ragmir-chat build && vitest run --coverage"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.3",
    "html-to-text": "^9.0.5",
    "mammoth": "^1.12.0",
    "picocolors": "^1.1.1",
    "read-excel-file": "^9.2.0",
    "unpdf": "^1.4.0",
    "yaml": "^2.9.0",
    "zod": "^4.1.13"
  },
  "peerDependencies": {
    "@jcode.labs/ragmir-chat": "workspace:*",
    "@jcode.labs/ragmir-tts": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@jcode.labs/ragmir-chat": {
      "optional": true
    },
    "@jcode.labs/ragmir-tts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jcode.labs/ragmir-chat": "workspace:*",
    "@jcode.labs/ragmir-tts": "workspace:*",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^24.10.1",
    "publint": "^0.3.21",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
