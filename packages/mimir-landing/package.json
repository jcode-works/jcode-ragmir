{
  "name": "@jcode.labs/mimir-landing",
  "version": "0.4.10",
  "private": true,
  "description": "Static Mimir landing page built with Astro.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "astro check && astro build",
    "cf:dry-run": "pnpm build && wrangler deploy --dry-run",
