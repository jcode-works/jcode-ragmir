    "dev": "astro dev",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@jcode.labs/mimir-ui": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "lucide-react": "^1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "wrangler": "^4.105.0"
  }
}
