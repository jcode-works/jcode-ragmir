---
import { ClientRouter } from "astro:transitions"
import "../styles/global.css"

interface Props {
  title?: string
  description?: string
  keywords?: string
  locale?: string
  ogType?: string
  ogImage?: string
  ogImageAlt?: string
  twitterCard?: string
  author?: string
  robots?: string
  structuredData?: Record<string, unknown> | Record<string, unknown>[]
  canonicalOverride?: string
  availableLocales?: readonly string[] | string[]
}

const {
  title = "Ragmir",
  description = "Sovereign local RAG for confidential dossiers and AI agents.",
  keywords,
  locale = "en",
  ogType = "website",
  ogImage = "/og/ragmir-og.png",
  ogImageAlt = "Ragmir open-source local RAG for confidential documents",
  twitterCard = "summary_large_image",
  author = "Jean-Baptiste Thery",
  robots: robotsProp = "index, follow",
  structuredData,
  canonicalOverride,
  availableLocales = ["en", "fr"],
} = Astro.props

const siteBase = Astro.site ?? new URL("https://ragmir.com")
const canonicalURL = canonicalOverride
  ? new URL(canonicalOverride, siteBase)
  : new URL(Astro.url.pathname, siteBase)
const ogImageUrl = new URL(ogImage, siteBase)
const isProduction = siteBase.hostname === "ragmir.com"
const robots = isProduction ? robotsProp : "noindex, nofollow, noarchive, nosnippet, noimageindex"
const localesForAlternates = Array.from(new Set(availableLocales)).filter((entry) =>
  ["en", "fr"].includes(entry),
)
const hreflangLocaleMap: Record<string, string> = {
  en: "en-US",
  fr: "fr-FR",
}
const ogLocaleMap: Record<string, string> = {
  en: "en_US",
  fr: "fr_FR",
}
const currentOgLocale = ogLocaleMap[locale] ?? "en_US"
const alternateOgLocales = localesForAlternates
  .filter((entry) => entry !== locale)
  .map((entry) => ogLocaleMap[entry] ?? "en_US")

function getImageType(imageUrl: string): string {
  const pathname = new URL(imageUrl, siteBase).pathname.toLowerCase()
  if (pathname.endsWith(".svg")) return "image/svg+xml"
  if (pathname.endsWith(".webp")) return "image/webp"
  if (pathname.endsWith(".jpg") || pathname.endsWith(".jpeg")) return "image/jpeg"
  if (pathname.endsWith(".gif")) return "image/gif"
  return "image/png"
}

function alternateHref(targetLocale: string): string {
  const currentPath = Astro.url.pathname
  const basePath = currentPath.replace(/^\/fr(?=\/|$)/, "") || "/"
  const localizedPath = targetLocale === "en" ? basePath : `/fr${basePath === "/" ? "/" : basePath}`
  return new URL(localizedPath, siteBase).href
}
---

<!doctype html>
<html lang={locale} dir="ltr" class="dark" translate="no">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      ;(() => {
        function safeStorageGet(key) {
          try {
            return localStorage.getItem(key)
          } catch {
            return null
          }
        }
        const theme = safeStorageGet("theme")
        const isDark = theme !== "light"
        document.documentElement.classList.toggle("dark", isDark)
        let colorSchemeMeta = document.querySelector('meta[name="color-scheme"]')
        if (!colorSchemeMeta) {
          colorSchemeMeta = document.createElement("meta")
          colorSchemeMeta.name = "color-scheme"
          document.head.appendChild(colorSchemeMeta)
        }
        colorSchemeMeta.content = isDark ? "dark" : "light"
      })()
    </script>
    <style>
      :root {
        --background: #000000;
      }
      html,
      body {
        background-color: var(--background);
      }
    </style>

    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="viewport-fit=cover, width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content={author} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" href="/llms.txt" type="text/plain" title="LLM instructions" />
    <link rel="alternate" href="/ai.txt" type="text/plain" title="AI instructions" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/inter-latin-500-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-600-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-900-normal.woff2" as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={getImageType(ogImageUrl.href)} />
    <meta property="og:locale" content={currentOgLocale} />
    <meta property="og:site_name" content="Ragmir" />
    {alternateOgLocales.map((entry) => <meta property="og:locale:alternate" content={entry} />)}

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {
      localesForAlternates.map((entry) => (
        <link rel="alternate" hreflang={hreflangLocaleMap[entry]} href={alternateHref(entry)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={alternateHref("en")} />

    {
      structuredData &&
        (Array.isArray(structuredData) ? (
          structuredData.map((data) => (
            <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
          ))
        ) : (
          <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
        ))
    }

    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="relative min-h-dvh">
    <slot />
  </body>
</html>
