---
import { CommandCopyToast } from "../../components/command-copy-toast"
import { LibrarySection } from "../../components/library-section"
import { LandingNavbar } from "../../components/landing-navbar"
import { getFaqItems } from "../../content/faq"
import Agents from "../../components/sections/agents.astro"
import ClosingCta from "../../components/sections/closing-cta.astro"
import Faq from "../../components/sections/faq.astro"
import Features from "../../components/sections/features.astro"
import Footer from "../../components/sections/footer.astro"
import Hero from "../../components/sections/hero.astro"
import Privacy from "../../components/sections/privacy.astro"
import Strengths from "../../components/sections/strengths.astro"
import UseCases from "../../components/sections/use-cases.astro"
import { defaultLang, getLocalizedUrl, languages, locales, useTranslations } from "../../i18n/utils"
import Layout from "../../layouts/layout.astro"

export function getStaticPaths() {
  return locales.map((locale) => ({
    params: { locale: locale === defaultLang ? undefined : locale },
  }))
}

const locale = (Astro.params.locale as string | undefined) ?? defaultLang
const { t, translations } = await useTranslations(locale)
const alternateLocales = locales.map((entry) => ({
  locale: entry,
  label: languages[entry],
  href: getLocalizedUrl("/", entry),
}))
const siteUrl = new URL("/", Astro.site ?? "https://ragmir.com").href
const pageUrl = new URL(getLocalizedUrl("/", locale), Astro.site ?? "https://ragmir.com").href
const publicVersion = import.meta.env.PUBLIC_RAGMIR_VERSION?.trim()
const faqItems = getFaqItems(translations)
const sourceDescription =
  "Open-source TypeScript RAG library, CLI, and local MCP server for cited offline retrieval from confidential project files."
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://ragmir.com/#organization",
    name: "JCode Labs",
    url: "https://github.com/jcode-works",
    founder: {
      "@type": "Person",
      "@id": "https://ragmir.com/#jb-thery",
      name: "Jean-Baptiste Thery",
      url: "https://github.com/jb-thery",
      sameAs: ["https://github.com/jb-thery"],
    },
    knowsAbout: [
      "local-first retrieval",
      "confidential local RAG",
      "confidential document search",
      "Model Context Protocol",
      "AI agent tooling",
      "Node.js RAG library",
    ],
    sameAs: ["https://github.com/jcode-works"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://ragmir.com/#website",
    url: siteUrl,
    name: "Ragmir",
    description: sourceDescription,
    inLanguage: ["en", "fr"],
    publisher: { "@id": "https://ragmir.com/#organization" },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "@id": "https://ragmir.com/#source",
    name: "Ragmir",
    description: sourceDescription,
    abstract: sourceDescription,
    url: siteUrl,
    inLanguage: ["en", "fr"],
    codeRepository: "https://github.com/jcode-works/jcode-ragmir",
    codeSampleType: "full solution",
    runtimePlatform: "Node.js 22 on Linux x64 or macOS ARM64",
    programmingLanguage: "TypeScript",
    keywords: ["local RAG", "coding agents", "cited retrieval", "MCP", "TypeScript"],
    license: "https://github.com/jcode-works/jcode-ragmir/blob/main/LICENSE",
    isAccessibleForFree: true,
    ...(publicVersion ? { version: publicVersion } : {}),
    isPartOf: {
      "@id": "https://ragmir.com/#website",
    },
    sameAs: [
      "https://github.com/jcode-works/jcode-ragmir",
      "https://www.npmjs.com/package/@jcode.labs/ragmir",
    ],
    publisher: {
      "@id": "https://ragmir.com/#organization",
    },
    author: {
      "@id": "https://ragmir.com/#jb-thery",
    },
    maintainer: {
      "@id": "https://ragmir.com/#jb-thery",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    url: `${pageUrl}#faq`,
    inLanguage: locale,
    isPartOf: { "@id": "https://ragmir.com/#website" },
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: t("seo_home_title"),
    description: t("seo_home_description"),
    inLanguage: locale,
    isPartOf: { "@id": "https://ragmir.com/#website" },
    about: { "@id": "https://ragmir.com/#source" },
    publisher: { "@id": "https://ragmir.com/#organization" },
  },
]
const localizedHomeUrl = `${getLocalizedUrl("/", locale)}#top`
const localizedLibraryUrl = `${getLocalizedUrl("/", locale)}#library`
const localizedFeaturesUrl = `${getLocalizedUrl("/", locale)}#features`
const localizedUseCasesUrl = `${getLocalizedUrl("/", locale)}#use-cases`
const localizedAgentsUrl = `${getLocalizedUrl("/", locale)}#agents`
const localizedTeamUrl = getLocalizedUrl("/team", locale)
---

<Layout
  title={t("seo_home_title")}
  description={t("seo_home_description")}
  author={t("seo_author")}
  robots={t("seo_robots")}
  ogImageAlt={t("seo_image_alt")}
  locale={locale}
  availableLocales={locales}
  structuredData={structuredData}
>
  <main class="relative min-h-screen overflow-hidden bg-background text-foreground">
    <LandingNavbar
      client:load
      alternateLocales={alternateLocales}
      locale={locale}
      localizedAgentsUrl={localizedAgentsUrl}
      localizedFeaturesUrl={localizedFeaturesUrl}
      localizedHomeUrl={localizedHomeUrl}
      localizedLibraryUrl={localizedLibraryUrl}
      localizedTeamUrl={localizedTeamUrl}
      localizedUseCasesUrl={localizedUseCasesUrl}
      translations={translations}
    />

    <Hero
      translations={translations}
      locale={locale}
      localizedLibraryUrl={localizedLibraryUrl}
      localizedUseCasesUrl={localizedUseCasesUrl}
    />

    <UseCases translations={translations} />

    <LibrarySection client:visible translations={translations} />

    <Features translations={translations} />

    <Agents translations={translations} />

    <Privacy translations={translations} />

    <Strengths translations={translations} />

    <Faq translations={translations} />

    <ClosingCta translations={translations} localizedLibraryUrl={localizedLibraryUrl} />

    <Footer
      localizedHomeUrl={localizedHomeUrl}
      translations={translations}
    />

    <CommandCopyToast client:idle message={t("command_copied")} />
  </main>
</Layout>
