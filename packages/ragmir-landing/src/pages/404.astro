---
import { RagmirBackground } from "../components/ragmir-background"
import { defaultLang, getLocalizedUrl } from "../i18n/utils"
import Layout from "../layouts/layout.astro"

const homeUrl = getLocalizedUrl("/", defaultLang)
---

<Layout
  title="Page not found | Ragmir"
  description="The page you are looking for does not exist or has moved."
  locale={defaultLang}
  robots="noindex, follow"
>
  <RagmirBackground
    behindContent={false}
    className="inset-0 min-h-[110dvh]"
    client:visible
    height="100dvh"
  />

  <main
    class="relative z-10 flex min-h-dvh flex-col items-center justify-center gap-6 px-5 text-center"
  >
    <a aria-label="Ragmir" class="flex items-center transition hover:opacity-80" href={homeUrl}>
      <span
        class="logo-stack font-black text-2xl text-foreground leading-none tracking-tight md:text-3xl"
        data-logo-text="Ragmir"
      >
        <span class="logo-index-1 logo-text">Ragmir</span>
      </span>
    </a>

    <p class="font-black text-[5rem] text-foreground leading-none md:text-[7rem]">404</p>
    <p class="max-w-md text-lg text-muted-foreground" data-i18n="desc">
      The page you are looking for does not exist or has moved.
    </p>

    <a
      class="rounded-full bg-[var(--primary)] px-6 py-3 font-bold text-[var(--primary-foreground)] text-sm transition hover:opacity-90"
      data-i18n="link"
      href={homeUrl}
    >
      <span data-i18n="btn">Back to Ragmir</span>
    </a>
  </main>

  {/* Localize French client-side from the URL path (/fr/...). */}
  <script is:inline>
    ;(() => {
      if (!/^\/fr(?:\/|$)/i.test(location.pathname)) return
      const desc = document.querySelector('[data-i18n="desc"]')
      const btn = document.querySelector('[data-i18n="btn"]')
      const link = document.querySelector('[data-i18n="link"]')
      if (desc) desc.textContent = "Cette page n'existe pas ou a été déplacée."
      if (btn) btn.textContent = "Retour à l'accueil"
      if (link) link.setAttribute("href", "/fr/")
      document.documentElement.setAttribute("lang", "fr")
    })()
  </script>
</Layout>
