---
import {
  Bot,
  Library,
  MessageSquareText,
  Quote,
  SearchCheck,
  ShieldCheck,
  Volume2,
  WifiOff,
} from "@lucide/astro"
import { CommandCopyBox } from "../command-copy"
import { RagmirBackground } from "../ragmir-background"

interface Props {
  translations: Record<string, string>
}

const { translations } = Astro.props
const t = (key: string): string => translations[key] ?? key

const featureGroups = [
  {
    icon: Library,
    title: t("features_core_title"),
    badge: t("features_core_badge"),
    installCommand: "npm install -D @jcode.labs/ragmir",
    command: "npx rgr setup",
    text: t("features_core_text"),
    items: [
      { icon: SearchCheck, text: t("features_core_item_1") },
      { icon: Quote, text: t("features_core_item_2") },
      { icon: Bot, text: t("features_core_item_3") },
      { icon: ShieldCheck, text: t("features_core_item_4") },
    ],
  },
  {
    icon: Volume2,
    title: t("features_tts_title"),
    badge: t("features_optional_badge"),
    installCommand: "npm install -D @jcode.labs/ragmir @jcode.labs/ragmir-tts",
    command: "npx rgr audio ./public-brief.md --allow-remote-models",
    text: t("features_tts_text"),
    items: [
      { icon: Volume2, text: t("features_tts_item_1") },
      { icon: Quote, text: t("features_tts_item_2") },
      { icon: WifiOff, text: t("features_tts_item_3") },
      { icon: ShieldCheck, text: t("features_tts_item_4") },
    ],
  },
  {
    icon: MessageSquareText,
    title: t("features_chat_title"),
    badge: t("features_optional_badge"),
    installCommand: "npm install -D @jcode.labs/ragmir @jcode.labs/ragmir-chat",
    command: "npx rgr chat setup --profile fast",
    text: t("features_chat_text"),
    items: [
      { icon: MessageSquareText, text: t("features_chat_item_1") },
      { icon: Quote, text: t("features_chat_item_2") },
      { icon: WifiOff, text: t("features_chat_item_3") },
      { icon: Bot, text: t("features_chat_item_4") },
    ],
  },
]
---

<section
  id="features"
  aria-labelledby="features-heading"
  class="relative z-10 w-full overflow-hidden py-24 md:py-36"
>
  <RagmirBackground client:visible behindContent className="inset-0" height="100%" />

  <div class="container-wide px-5 md:px-8">
    <div class="mb-10 max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-muted-foreground">
        {t("features_eyebrow")}
      </p>
      <h2 id="features-heading" class="mt-4 font-black text-2xl leading-tight md:text-3xl">
        {t("features_title")}
      </h2>
      <p class="mt-5 max-w-3xl text-muted-foreground text-sm leading-6">
        {t("features_text")}
      </p>
    </div>

    <div class="grid auto-rows-fr gap-4 lg:grid-cols-3">
      {featureGroups.map((group) => (
        <article class="grid h-full grid-rows-[auto_auto_auto_auto_1fr] rounded-md border border-border bg-card/82 p-5 text-card-foreground shadow-xl shadow-black/20 backdrop-blur-xl md:p-6">
          <div class="flex items-center justify-between gap-3">
            <div class="flex size-11 items-center justify-center rounded-sm border border-border bg-muted/60">
              <group.icon class="size-5 text-[var(--accent-title)]" aria-hidden="true" />
            </div>
            <span class="rounded-sm border border-border bg-muted/55 px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.14em] text-muted-foreground">
              {group.badge}
            </span>
          </div>
          <h3 class="mt-5 font-black text-xl leading-tight">{group.title}</h3>
          <p class="mt-3 min-h-12 text-muted-foreground text-sm leading-6">{group.text}</p>
          <div class="mt-5 grid gap-3">
            <div class="min-h-[5.25rem]">
              <p class="mb-2 text-[0.65rem] font-bold uppercase tracking-[0.14em] text-muted-foreground">
                {t("features_install_label")}
              </p>
              <CommandCopyBox
                client:visible
                command={group.installCommand}
                copyLabel={t("copy_command")}
              />
            </div>
            <div class="min-h-[5.25rem]">
              <p class="mb-2 text-[0.65rem] font-bold uppercase tracking-[0.14em] text-muted-foreground">
                {t("features_run_label")}
              </p>
              <CommandCopyBox
                client:visible
                command={group.command}
                copyLabel={t("copy_command")}
              />
            </div>
          </div>
          <ul class="mt-6 grid content-start gap-3 border-t border-border pt-5">
            {group.items.map((item) => (
              <li class="flex gap-3 text-sm leading-6">
                <item.icon class="mt-0.5 size-4 shrink-0 text-muted-foreground" aria-hidden="true" />
                <span class="text-foreground/88">{item.text}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
