---
import { Check, CodeXml, FileSearch, Link2, ShieldCheck } from "@lucide/astro"
import { RagmirBackground } from "../ragmir-background"

interface Props {
  translations: Record<string, string>
}

const { translations } = Astro.props
const t = (key: string): string => translations[key] ?? key

const bestAt = [
  {
    icon: FileSearch,
    title: t("strengths_best_item_1_title"),
    text: t("strengths_best_item_1"),
  },
  {
    icon: CodeXml,
    title: t("strengths_best_item_2_title"),
    text: t("strengths_best_item_2"),
  },
  {
    icon: ShieldCheck,
    title: t("strengths_best_item_3_title"),
    text: t("strengths_best_item_3"),
  },
  {
    icon: Link2,
    title: t("strengths_best_item_4_title"),
    text: t("strengths_best_item_4"),
  },
]
const lessUseful = [
  t("strengths_limits_item_1"),
  t("strengths_limits_item_2"),
  t("strengths_limits_item_3"),
]
---

<section
  aria-labelledby="strengths-heading"
  class="relative z-10 w-full overflow-hidden py-24 md:py-36"
>
  <RagmirBackground client:visible behindContent className="inset-0" height="100%" />

  <div class="container-wide px-5 md:px-8">
    <div class="mb-10 grid gap-5 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-muted-foreground">
          {t("strengths_eyebrow")}
        </p>
        <h2
          id="strengths-heading"
          class="mt-4 max-w-2xl font-black text-2xl leading-tight md:text-3xl"
        >
          {t("strengths_title")}
        </h2>
      </div>
      <p class="max-w-3xl text-muted-foreground text-sm leading-6 lg:justify-self-end">
        {t("strengths_text")}
      </p>
    </div>

    <div class="grid gap-4 lg:grid-cols-[1.35fr_0.65fr]">
      <article class="rounded-md border border-border bg-card/85 p-5 shadow-xl shadow-black/20 backdrop-blur-xl md:p-8">
        <div class="mb-6 flex items-center gap-3">
          <span class="flex size-9 items-center justify-center rounded-full bg-[var(--accent-title)]/15">
            <Check class="size-4 text-[var(--accent-title)]" aria-hidden="true" />
          </span>
          <h3 class="font-black text-lg">{t("strengths_best_title")}</h3>
        </div>

        <div class="grid gap-x-8 gap-y-6 sm:grid-cols-2">
          {bestAt.map((item, index) => (
            <div class="border-border border-t pt-5">
              <div class="flex items-start gap-3">
                <span class="font-mono text-muted-foreground text-xs">0{index + 1}</span>
                <item.icon class="mt-0.5 size-5 shrink-0 text-[var(--accent-title)]" aria-hidden="true" />
              </div>
              <h4 class="mt-4 font-black text-base leading-snug">{item.title}</h4>
              <p class="mt-2 text-muted-foreground text-sm leading-6">{item.text}</p>
            </div>
          ))}
        </div>
      </article>

      <aside class="flex flex-col rounded-md border border-border bg-card/72 p-5 shadow-xl shadow-black/20 backdrop-blur-xl md:p-8">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-muted-foreground">
          {t("strengths_limits_eyebrow")}
        </p>
        <h3 class="mt-3 font-black text-xl leading-tight">{t("strengths_limits_title")}</h3>
        <p class="mt-3 text-muted-foreground text-sm leading-6">{t("strengths_limits_text")}</p>

        <ul class="mt-6 flex flex-col gap-4">
          {lessUseful.map((item) => (
            <li class="flex gap-3 text-sm leading-6">
              <Check class="mt-0.5 size-4 shrink-0 text-muted-foreground" aria-hidden="true" />
              <span class="text-foreground/82">{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-auto pt-8">
          <p class="font-mono text-foreground/70 text-xs">MCP · CLI · TypeScript</p>
        </div>
      </aside>
    </div>
  </div>
</section>
