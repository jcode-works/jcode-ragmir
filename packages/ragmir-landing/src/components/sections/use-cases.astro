---
import { UseCaseCarousel } from "../use-case-carousel"

interface Props {
  translations: Record<string, string>
}

const { translations } = Astro.props
const t = (key: string): string => translations[key] ?? key

---

<section
  id="use-cases"
  aria-labelledby="use-cases-heading"
  class="container-default relative z-10 px-5 py-24 md:px-8 md:py-40"
>
  <div class="mb-8 max-w-3xl">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-muted-foreground">
      {t("use_cases_eyebrow")}
    </p>
    <h2 id="use-cases-heading" class="mt-4 font-black text-2xl leading-tight md:text-3xl">
      {t("use_cases_title")}
    </h2>
    <p class="mt-4 text-muted-foreground text-sm leading-6">{t("use_cases_text")}</p>
  </div>

  <UseCaseCarousel client:visible translations={translations} />
</section>
