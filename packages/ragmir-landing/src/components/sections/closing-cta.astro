---
import { ArrowRight } from "@lucide/astro"

interface Props {
  translations: Record<string, string>
  localizedLibraryUrl: string
}

const { translations, localizedLibraryUrl } = Astro.props
const t = (key: string): string => translations[key] ?? key
---

<section id="cta-final" class="container-wide relative w-full overflow-hidden">
  <div class="relative flex flex-col min-h-[60vh]">
    <div class="container-default mx-auto w-full px-5 pt-12 md:pt-16">
      <div class="flex justify-between text-[10px] font-mono tracking-[0.25em] uppercase text-muted-foreground">
        <span>{t("closing_eyebrow")}</span>
        <span class="hidden md:inline">{t("closing_open_source")}</span>
      </div>
    </div>

    <div class="flex flex-1 items-center justify-center px-5 text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="display-title font-black text-3xl leading-[1.06] sm:text-4xl lg:text-5xl">
          <span class="block">{t("closing_title")}</span>
        </h2>
        <p class="mt-2 text-muted-foreground text-sm leading-6 md:text-base">
          {t("closing_text")}
        </p>
        <div class="mt-8 flex flex-col items-center gap-3">
          <a
            class="inline-flex h-14 w-full items-center justify-center gap-2 rounded-full bg-primary px-8 text-sm font-bold text-primary-foreground transition hover:bg-primary/90 md:w-auto"
            href={localizedLibraryUrl}
          >
            {t("closing_secondary_cta")}
            <ArrowRight class="size-4" />
          </a>
          <a
            href="https://github.com/jcode-works/jcode-ragmir"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 text-[11px] text-muted-foreground tracking-wide no-underline transition hover:text-foreground"
          >
            {t("closing_primary_cta")} | github.com/jcode-works/jcode-ragmir
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
