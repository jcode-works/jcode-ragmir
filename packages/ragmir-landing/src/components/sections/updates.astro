---
import { ArrowUpRight, Braces, History, Tags } from "@lucide/astro"
import { RagmirBackground } from "../ragmir-background"

interface Props {
  translations: Record<string, string>
}

const { translations } = Astro.props
const t = (key: string): string => translations[key] ?? key
const version = import.meta.env.PUBLIC_RAGMIR_VERSION

const updateLinks = [
  {
    href: "https://github.com/jcode-works/jcode-ragmir/releases/latest",
    icon: Tags,
    title: t("updates_releases_title"),
    text: t("updates_releases_text"),
    link: t("updates_releases_link"),
  },
  {
    href: "https://github.com/jcode-works/jcode-ragmir/blob/main/CHANGELOG.md",
    icon: History,
    title: t("updates_changelog_title"),
    text: t("updates_changelog_text"),
    link: t("updates_changelog_link"),
  },
  {
    href: "https://github.com/jcode-works/jcode-ragmir/blob/main/docs/api-reference.md",
    icon: Braces,
    title: t("updates_api_title"),
    text: t("updates_api_text"),
    link: t("updates_api_link"),
  },
]
---

<section
  id="updates"
  aria-labelledby="updates-heading"
  class="container-default relative z-10 px-5 py-24 md:px-8 md:py-40"
>
  <RagmirBackground client:visible behindContent className="inset-0" height="calc(100% + 8rem)" />

  <div class="relative overflow-hidden rounded-2xl border border-border bg-card/82 shadow-2xl shadow-black/30">
    <div class="grid border-b border-border lg:grid-cols-[1.2fr_0.8fr]">
      <div class="p-6 md:p-10 lg:p-12">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-muted-foreground">
          {t("updates_eyebrow")}
        </p>
        <h2 id="updates-heading" class="mt-4 max-w-2xl font-black text-2xl leading-tight md:text-3xl">
          {t("updates_title")}
        </h2>
        <p class="mt-4 max-w-2xl text-muted-foreground text-sm leading-6">
          {t("updates_text")}
        </p>
      </div>

      <div class="flex min-h-52 flex-col justify-between border-t border-border bg-background/65 p-6 lg:border-t-0 lg:border-l lg:p-10">
        <span class="font-mono text-xs font-bold uppercase tracking-[0.18em] text-muted-foreground">
          {t("updates_version_label")}
        </span>
        <strong class="font-mono text-5xl tracking-tighter text-[var(--accent-title)] md:text-6xl">
          v{version}
        </strong>
        <span class="max-w-sm text-muted-foreground text-xs leading-5">
          {t("updates_version_text")}
        </span>
      </div>
    </div>

    <div class="grid lg:grid-cols-3">
      {updateLinks.map((item, index) => (
        <a
          class:list={[
            "group flex min-h-64 flex-col justify-between p-6 transition hover:bg-muted/50 md:p-8",
            index > 0 && "border-t border-border lg:border-t-0 lg:border-l",
          ]}
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div>
            <item.icon class="size-5 text-[var(--accent-title)]" aria-hidden="true" />
            <h3 class="mt-8 font-semibold text-lg leading-tight">{item.title}</h3>
            <p class="mt-3 text-muted-foreground text-sm leading-6">{item.text}</p>
          </div>
          <span class="mt-8 inline-flex items-center gap-2 font-bold text-sm text-foreground">
            {item.link}
            <ArrowUpRight class="size-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" aria-hidden="true" />
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
