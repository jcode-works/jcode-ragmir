---
import RagmirLogo from "../ragmir-logo.astro"
import { RagmirBackground } from "../ragmir-background"

interface Props {
  translations: Record<string, string>
  localizedHomeUrl: string
}

const { translations, localizedHomeUrl } = Astro.props
const t = (key: string): string => translations[key] ?? key
const version = import.meta.env.PUBLIC_RAGMIR_VERSION?.trim()

const footerLinks = [
  { href: "https://github.com/jcode-works/jcode-ragmir", label: t("nav_github") },
  { href: "https://www.npmjs.com/package/@jcode.labs/ragmir", label: t("footer_link_npm") },
  { href: "https://github.com/jcode-works/jcode-ragmir/wiki", label: t("footer_link_docs") },
  { href: "https://github.com/jcode-works/jcode-ragmir/releases/latest", label: t("footer_link_releases") },
  { href: "https://github.com/jcode-works/jcode-ragmir/blob/main/CHANGELOG.md", label: t("footer_link_changelog") },
  { href: "https://github.com/jcode-works/jcode-ragmir/blob/main/docs/api-reference.md", label: t("footer_link_api") },
]

const marqueeCopy =
  "whitespace-nowrap pr-8 font-black text-5xl text-foreground/90 uppercase italic leading-[1.1] tracking-tighter md:pr-14 md:text-7xl"
---

<footer class="relative z-10 mt-10 overflow-hidden">
  <div class="relative isolate overflow-hidden pt-16 pb-10">
    <RagmirBackground
      client:visible
      behindContent={false}
      className="inset-0"
      height="100%"
    />

    <div class="relative z-10 mx-auto flex max-w-7xl flex-col items-center gap-6 px-5 text-center md:px-8">
      <a
        aria-label="Ragmir"
        class="flex items-center transition hover:opacity-80"
        href={localizedHomeUrl}
      >
        <RagmirLogo />
      </a>
      <nav aria-label={t("footer_nav_label")}>
        <ul class="grid grid-cols-2 items-center justify-center gap-x-8 gap-y-3 sm:flex sm:flex-wrap">
          {footerLinks.map((link) => (
            <li>
              <a
                class="font-semibold text-foreground text-sm transition hover:opacity-80"
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div
      aria-hidden="true"
      class="relative z-10 my-10 overflow-hidden py-3"
    >
      <div class="flex w-max animate-marquee-text">
        <span class={marqueeCopy}>{t("footer_marquee")}</span>
        <span class={marqueeCopy}>{t("footer_marquee")}</span>
      </div>
    </div>

    <div
      class="relative z-10 mx-auto flex max-w-3xl flex-col items-center justify-center gap-3 px-5 text-center text-foreground/90 text-xs leading-5 md:px-8"
    >
      <p>{t("footer_text")}</p>
      {version && (
        <a
          href="https://www.npmjs.com/package/@jcode.labs/ragmir"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${t("footer_version_label")}: v${version}`}
          class="font-semibold text-foreground no-underline transition hover:opacity-80"
        >
          v{version}
        </a>
      )}
    </div>
  </div>
</footer>
