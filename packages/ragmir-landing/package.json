{
  "name": "@jcode.labs/ragmir-landing",
  "version": "0.4.10",
  "private": true,
  "description": "Static Ragmir landing page built with Astro.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/astro-no-telemetry.mjs check && node scripts/astro-no-telemetry.mjs build",
    "cf:dry-run": "pnpm build && wrangler deploy --dry-run",
    "cf:preview": "pnpm build && wrangler dev --local --port 8787",
    "check": "node scripts/astro-no-telemetry.mjs check",
    "dev": "node scripts/astro-no-telemetry.mjs dev",
    "preview": "node scripts/astro-no-telemetry.mjs preview",
    "submit:indexnow": "node scripts/submit-indexnow.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@gsap/react": "^2.1.2",
    "@jcode.labs/ragmir-ui": "workspace:*",
    "@lucide/astro": "^1.23.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "gsap": "^3.15.0",
    "lucide-react": "^1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "wrangler": "^4.107.0",
    "xml2js": "^0.6.2"
  }
}
