{
  "name": "@jcode.labs/ragmir-chat",
  "version": "0.4.12",
  "description": "Optional cited local answer generation after Ragmir Core retrieval with verified GGUF models.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Jean-Baptiste Thery",
    "url": "https://github.com/jb-thery"
  },
  "keywords": [
    "jcode",
    "ragmir",
    "local-chat",
    "offline-ai",
    "local-first",
    "gemma",
    "qwen",
    "local-llm",
    "llama-cpp",
    "private-ai",
    "rag"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcode-works/jcode-ragmir.git",
    "directory": "packages/ragmir-chat"
  },
  "homepage": "https://github.com/jcode-works/jcode-ragmir#readme",
  "bugs": {
    "url": "https://github.com/jcode-works/jcode-ragmir/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ragmir-chat": "dist/cli.js",
    "rgr-chat": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "package:check": "publint",
    "smoke": "node dist/cli.js doctor --json",
    "test": "vitest run"
  },
  "dependencies": {
    "node-llama-cpp": "3.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "publint": "^0.3.21",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
